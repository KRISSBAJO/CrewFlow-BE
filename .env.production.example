NODE_ENV="production"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/crewflow?schema=public&sslmode=require"
JWT_SECRET="generate-a-long-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="1d"
PORT=3002
CORS_ORIGIN="https://app.yourdomain.com"
PUBLIC_API_URL="https://api.yourdomain.com/api"

WHATSAPP_VERIFY_TOKEN="set-a-strong-meta-verify-token"
WHATSAPP_ACCESS_TOKEN="meta-whatsapp-cloud-api-token"
WHATSAPP_PHONE_NUMBER_ID="meta-phone-number-id"
WHATSAPP_APP_SECRET="meta-app-secret"
WHATSAPP_BUSINESS_ACCOUNT_ID="meta-business-account-id"

OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1-mini"

STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
PAYSTACK_SECRET_KEY="sk_live_..."
PAYSTACK_CURRENCY="NGN"
PAYSTACK_PLATFORM_PLAN_CODE="paystack-platform-plan-code"
PAYSTACK_TENANT_PLAN_CODE="paystack-tenant-plan-code"

PAYMENT_SUCCESS_URL="https://app.yourdomain.com/app?payment=success"
PAYMENT_CANCEL_URL="https://app.yourdomain.com/app?payment=cancel"
PLATFORM_BILLING_SUCCESS_URL="https://app.yourdomain.com/admin?billing=success"
PLATFORM_BILLING_CANCEL_URL="https://app.yourdomain.com/admin?billing=cancel"
PLATFORM_BILLING_PORTAL_RETURN_URL="https://app.yourdomain.com/admin"
TENANT_BILLING_SUCCESS_URL="https://app.yourdomain.com/app?billing=success"
TENANT_BILLING_CANCEL_URL="https://app.yourdomain.com/app?billing=cancel"
TENANT_BILLING_PORTAL_RETURN_URL="https://app.yourdomain.com/app?view=settings"

RATE_LIMIT_ENABLED="true"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="240"
TRUST_PROXY="true"
SWAGGER_ENABLED="false"
ENABLE_SCHEDULER="true"
SCHEDULER_INTERVAL_MS="300000"
ALLOW_DEMO_SEED="false"
