generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageProvider {
  WHATSAPP
  SMS
  WEB_CHAT
  EMAIL
  SYSTEM
}

enum AutomationTrigger {
  BOOKING_CONFIRMED
  STAFF_ON_THE_WAY
  MISSED_APPOINTMENT
  INVOICE_DUE
  REVIEW_REQUEST
}

enum AutomationRunStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WebhookProvider {
  WHATSAPP
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum ConversationStatus {
  OPEN
  BOOKING_READY
  HANDED_OFF
  CLOSED
}

enum ConversationMessageRole {
  CUSTOMER
  ASSISTANT
  STAFF
  SYSTEM
}

enum BookingIntentStatus {
  COLLECTING
  READY
  BOOKED
  HANDED_OFF
  CANCELLED
}

model Tenant {
  id               String            @id @default(cuid())
  businessName     String
  slug             String            @unique
  industry         String
  subscriptionPlan String            @default("pilot")
  invoiceCounter   Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  customers        Customer[]
  services         Service[]
  bookings         Booking[]
  attendance       Attendance[]
  invoices         Invoice[]
  invoiceLineItems InvoiceLineItem[]
  messages         MessageLog[]
  automations      AutomationRule[]
  automationRuns   AutomationRun[]
  webhookEvents    WebhookEvent[]
  receptionistConfig ReceptionistConfig?
  conversations    Conversation[]
  conversationMessages ConversationMessage[]
  bookingIntents   BookingIntent[]
  auditLogs        AuditLog[]
}

model User {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         UserRole     @default(STAFF)
  phone        String?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings     Booking[]    @relation("AssignedStaff")
  attendance   Attendance[]
  auditLogs     AuditLog[]
  handedOffConversations Conversation[] @relation("ConversationHandoff")

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model Customer {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  email     String?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  invoices  Invoice[]
  messages  MessageLog[]
  automationRuns AutomationRun[]
  conversations Conversation[]
  bookingIntents BookingIntent[]

  @@unique([tenantId, phone])
  @@index([tenantId, name])
}

model Service {
  id              String    @id @default(cuid())
  tenantId        String
  title           String
  description     String?
  durationMinutes Int
  priceCents      Int
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  bookingIntents  BookingIntent[]

  @@unique([tenantId, title])
  @@index([tenantId, active])
}

model Booking {
  id              String        @id @default(cuid())
  tenantId        String
  customerId      String
  serviceId       String
  assignedStaffId String?
  startTime       DateTime
  endTime         DateTime?
  status          BookingStatus @default(REQUESTED)
  source          String        @default("manual")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id])
  service         Service       @relation(fields: [serviceId], references: [id])
  assignedStaff   User?         @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  invoice         Invoice?
  automationRuns  AutomationRun[]
  bookingIntents  BookingIntent[]

  @@index([tenantId, startTime])
  @@index([tenantId, status])
  @@index([tenantId, assignedStaffId])
}

model Attendance {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  checkIn      DateTime  @default(now())
  checkOut     DateTime?
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  notes        String?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, checkIn])
}

model Invoice {
  id            String            @id @default(cuid())
  tenantId      String
  customerId    String
  bookingId     String?           @unique
  invoiceNo     String
  subtotalCents Int
  taxCents      Int               @default(0)
  totalCents    Int
  dueDate       DateTime
  status        InvoiceStatus     @default(DRAFT)
  paidAt        DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer          @relation(fields: [customerId], references: [id])
  booking       Booking?          @relation(fields: [bookingId], references: [id])
  lineItems     InvoiceLineItem[]
  automationRuns AutomationRun[]

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  tenantId    String
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitCents   Int
  totalCents  Int
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
}

model MessageLog {
  id          String           @id @default(cuid())
  tenantId    String
  customerId  String?
  direction   MessageDirection
  provider    MessageProvider
  content     String
  metadata    Json?
  createdAt   DateTime         @default(now())
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer?        @relation(fields: [customerId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, customerId])
}

model AutomationRule {
  id             String            @id @default(cuid())
  tenantId       String
  trigger        AutomationTrigger
  provider       MessageProvider   @default(WHATSAPP)
  template       String
  active         Boolean           @default(true)
  delayMinutes   Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs           AutomationRun[]

  @@unique([tenantId, trigger])
  @@index([tenantId, active])
}

model AutomationRun {
  id             String              @id @default(cuid())
  tenantId       String
  ruleId         String?
  customerId     String?
  bookingId      String?
  invoiceId      String?
  trigger        AutomationTrigger
  provider       MessageProvider
  status         AutomationRunStatus @default(PENDING)
  scheduledFor   DateTime
  sentAt         DateTime?
  content        String?
  error          String?
  idempotencyKey String
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule           AutomationRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  customer       Customer?           @relation(fields: [customerId], references: [id])
  booking        Booking?            @relation(fields: [bookingId], references: [id])
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, trigger])
}

model WebhookEvent {
  id              String             @id @default(cuid())
  tenantId        String?
  provider        WebhookProvider
  providerEventId String?
  status          WebhookEventStatus @default(RECEIVED)
  payload         Json
  error           String?
  createdAt       DateTime           @default(now())
  processedAt     DateTime?
  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, providerEventId])
  @@index([tenantId, createdAt])
  @@index([provider, status])
}

model ReceptionistConfig {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  enabled              Boolean  @default(true)
  displayName          String   @default("AI Receptionist")
  tone                 String   @default("warm, concise, professional")
  businessHours        Json?
  serviceArea          String?
  fallbackMessage      String   @default("Thanks for reaching out. A team member will follow up shortly.")
  handoffKeywords      String[] @default(["manager", "human", "representative", "call me"])
  quoteDisclaimer      String   @default("Final pricing may change after confirming job details.")
  bookingBufferMinutes Int      @default(30)
  maxAdvanceDays       Int      @default(30)
  model                String   @default("gpt-4.1-mini")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String                @id @default(cuid())
  tenantId        String
  customerId      String?
  channel         MessageProvider       @default(WEB_CHAT)
  status          ConversationStatus    @default(OPEN)
  lastMessageAt   DateTime              @default(now())
  handedOffAt     DateTime?
  handedOffToId   String?
  handoffReason   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer?             @relation(fields: [customerId], references: [id])
  handedOffTo     User?                 @relation("ConversationHandoff", fields: [handedOffToId], references: [id])
  messages        ConversationMessage[]
  bookingIntents  BookingIntent[]

  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, customerId])
}

model ConversationMessage {
  id             String                  @id @default(cuid())
  tenantId       String
  conversationId String
  role           ConversationMessageRole
  content        String
  metadata       Json?
  createdAt      DateTime                @default(now())
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, createdAt])
}

model BookingIntent {
  id               String              @id @default(cuid())
  tenantId         String
  conversationId   String
  customerId       String?
  serviceId        String?
  bookingId        String?
  status           BookingIntentStatus @default(COLLECTING)
  requestedDate    DateTime?
  preferredWindow  String?
  address          String?
  notes            String?
  quotedPriceCents Int?
  missingFields    String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation     Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer         Customer?           @relation(fields: [customerId], references: [id])
  service          Service?            @relation(fields: [serviceId], references: [id])
  booking          Booking?            @relation(fields: [bookingId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, conversationId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId])
}
