generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
  OWNER
  MANAGER
  STAFF
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  ARCHIVED
  CHURNED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum BillingEventType {
  SETUP_FEE_INVOICED
  SETUP_FEE_PAID
  SUBSCRIPTION_STARTED
  SUBSCRIPTION_RENEWED
  PAYMENT_FAILED
  PAST_DUE
  CANCELED
  CREDIT_APPLIED
  REFUND_ISSUED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageProvider {
  WHATSAPP
  SMS
  WEB_CHAT
  EMAIL
  SYSTEM
}

enum AutomationTrigger {
  BOOKING_CONFIRMED
  STAFF_ON_THE_WAY
  MISSED_APPOINTMENT
  INVOICE_DUE
  REVIEW_REQUEST
  LEAD_FOLLOW_UP
  REBOOKING_REMINDER
  CUSTOMER_WINBACK
}

enum AutomationRunStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WhatsAppTemplateStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAUSED
}

enum WhatsAppTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

enum WebhookProvider {
  WHATSAPP
  STRIPE
  PAYSTACK
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum ConversationStatus {
  OPEN
  WAITING_ON_CUSTOMER
  BOOKING_READY
  HANDED_OFF
  RESOLVED
  CLOSED
}

enum ConversationMessageRole {
  CUSTOMER
  ASSISTANT
  STAFF
  SYSTEM
}

enum BookingIntentStatus {
  COLLECTING
  READY
  BOOKED
  HANDED_OFF
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKING_READY
  WON
  LOST
}

enum LeadSource {
  AI_RECEPTIONIST
  WEB_CHAT
  WHATSAPP
  SMS
  EMAIL
  PHONE
  REFERRAL
  MANUAL
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  MOCK
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum ActionType {
  CONFIRM_BOOKING
  DISPATCH_STAFF
  FOLLOW_UP_NO_SHOW
  COLLECT_PAYMENT
  REQUEST_REVIEW
  RESOLVE_STAFF_CONFLICT
  FOLLOW_UP_STALE_INQUIRY
  SUGGEST_REPEAT_BOOKING
  WIN_BACK_CUSTOMER
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

enum JobReportStatus {
  DRAFT
  COMPLETED
}

model Tenant {
  id                   String                  @id @default(cuid())
  businessName         String
  slug                 String                  @unique
  industry             String
  status               TenantStatus            @default(TRIAL)
  subscriptionStatus   SubscriptionStatus      @default(TRIALING)
  subscriptionPlan     String                  @default("pilot")
  subscriptionPlanId   String?
  logoUrl              String?
  coverImageUrl        String?
  brandColor           String?
  billingEmail         String?
  monthlyPriceCents    Int?
  setupFeeCents        Int?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  nextBillingAt        DateTime?
  pastDueAt            DateTime?
  canceledAt           DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  paystackCustomerCode String?
  paystackSubscriptionCode String?
  featureFlags         Json?
  planLimits           Json?
  suspendedAt          DateTime?
  invoiceCounter       Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  users                User[]
  customers            Customer[]
  services             Service[]
  bookings             Booking[]
  attendance           Attendance[]
  invoices             Invoice[]
  invoiceLineItems     InvoiceLineItem[]
  payments             Payment[]
  operationalActions   OperationalAction[]
  fieldJobReports      FieldJobReport[]
  messages             MessageLog[]
  automations          AutomationRule[]
  whatsappTemplates    WhatsAppTemplate[]
  automationRuns       AutomationRun[]
  webhookEvents        WebhookEvent[]
  receptionistConfig   ReceptionistConfig?
  conversations        Conversation[]
  conversationMessages ConversationMessage[]
  bookingIntents       BookingIntent[]
  leads                Lead[]
  auditLogs            AuditLog[]
  supportNotes         PlatformSupportNote[]
  supportAccessLogs    PlatformSupportAccess[]
  billingEvents        PlatformBillingEvent[]
  onboardingProfile    OnboardingProfile?
  plan                 SubscriptionPlan?       @relation(fields: [subscriptionPlanId], references: [id])

  @@index([subscriptionPlanId])
}

model SubscriptionPlan {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  description        String?
  active             Boolean  @default(true)
  currency           String   @default("USD")
  monthlyPriceCents  Int      @default(0)
  setupFeeCents      Int      @default(0)
  stripePriceId      String?
  paystackPlanCode   String?
  featureFlags       Json?
  planLimits         Json?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenants            Tenant[]
}

model OnboardingProfile {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  ownerName      String
  ownerEmail     String
  ownerPhone     String?
  staffCount     String?
  whatsappNumber String?
  services       String[] @default([])
  biggestProblem String?
  setupStatus    String   @default("INTAKE_COMPLETE")
  source         String   @default("landing")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                     String                  @id @default(cuid())
  tenantId               String
  name                   String
  email                  String
  passwordHash           String
  role                   UserRole                @default(STAFF)
  phone                  String?
  avatarUrl              String?
  active                 Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings               Booking[]               @relation("AssignedStaff")
  attendance             Attendance[]
  assignedActions        OperationalAction[]     @relation("ActionAssignee")
  assignedConversations  Conversation[]          @relation("ConversationAssignee")
  completedJobReports    FieldJobReport[]        @relation("JobReportCompletedBy")
  assignedLeads          Lead[]                  @relation("LeadAssignee")
  auditLogs              AuditLog[]
  handedOffConversations Conversation[]          @relation("ConversationHandoff")
  platformSupportNotes   PlatformSupportNote[]   @relation("PlatformSupportNoteAuthor")
  platformSupportAccess  PlatformSupportAccess[] @relation("PlatformSupportAccessAdmin")
  platformBillingEvents  PlatformBillingEvent[]  @relation("PlatformBillingEventActor")

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model Customer {
  id                 String              @id @default(cuid())
  tenantId           String
  name               String
  phone              String
  email              String?
  avatarUrl          String?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  invoices           Invoice[]
  messages           MessageLog[]
  automationRuns     AutomationRun[]
  conversations      Conversation[]
  bookingIntents     BookingIntent[]
  leads              Lead[]
  operationalActions OperationalAction[]

  @@unique([tenantId, phone])
  @@index([tenantId, name])
}

model Service {
  id              String          @id @default(cuid())
  tenantId        String
  title           String
  description     String?
  imageUrl        String?
  durationMinutes Int
  priceCents      Int
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  bookingIntents  BookingIntent[]

  @@unique([tenantId, title])
  @@index([tenantId, active])
}

model Booking {
  id                 String              @id @default(cuid())
  tenantId           String
  customerId         String
  serviceId          String
  assignedStaffId    String?
  startTime          DateTime
  endTime            DateTime?
  status             BookingStatus       @default(REQUESTED)
  source             String              @default("manual")
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer            @relation(fields: [customerId], references: [id])
  service            Service             @relation(fields: [serviceId], references: [id])
  assignedStaff      User?               @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  invoice            Invoice?
  automationRuns     AutomationRun[]
  bookingIntents     BookingIntent[]
  leads              Lead[]
  operationalActions OperationalAction[]
  fieldJobReport     FieldJobReport?

  @@index([tenantId, startTime])
  @@index([tenantId, status])
  @@index([tenantId, assignedStaffId])
}

model Attendance {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  checkIn   DateTime  @default(now())
  checkOut  DateTime?
  latitude  Float?
  longitude Float?
  photoUrl  String?
  notes     String?
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, checkIn])
}

model Invoice {
  id                 String              @id @default(cuid())
  tenantId           String
  customerId         String
  bookingId          String?             @unique
  invoiceNo          String
  subtotalCents      Int
  taxCents           Int                 @default(0)
  totalCents         Int
  dueDate            DateTime
  status             InvoiceStatus       @default(DRAFT)
  paidAt             DateTime?
  paymentUrl         String?
  paymentProvider    PaymentProvider?
  paymentReference   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer            @relation(fields: [customerId], references: [id])
  booking            Booking?            @relation(fields: [bookingId], references: [id])
  lineItems          InvoiceLineItem[]
  payments           Payment[]
  automationRuns     AutomationRun[]
  operationalActions OperationalAction[]

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  invoiceId         String
  provider          PaymentProvider @default(MOCK)
  status            PaymentStatus   @default(PENDING)
  amountCents       Int
  currency          String          @default("usd")
  checkoutUrl       String?
  providerPaymentId String?
  providerSessionId String?
  receiptUrl        String?
  paidAt            DateTime?
  failureReason     String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice           Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSessionId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, invoiceId])
}

model OperationalAction {
  id             String         @id @default(cuid())
  tenantId       String
  type           ActionType
  priority       ActionPriority @default(MEDIUM)
  status         ActionStatus   @default(OPEN)
  title          String
  description    String?
  customerId     String?
  bookingId      String?
  invoiceId      String?
  assignedToId   String?
  dueAt          DateTime?
  completedAt    DateTime?
  dismissedAt    DateTime?
  source         String         @default("workflow")
  idempotencyKey String
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer?      @relation(fields: [customerId], references: [id])
  booking        Booking?       @relation(fields: [bookingId], references: [id])
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id])
  assignedTo     User?          @relation("ActionAssignee", fields: [assignedToId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, priority, dueAt])
  @@index([tenantId, type])
}

model FieldJobReport {
  id                    String          @id @default(cuid())
  tenantId              String
  bookingId             String          @unique
  status                JobReportStatus @default(DRAFT)
  checklist             Json?
  photoUrls             String[]        @default([])
  staffNotes            String?
  customerSignatureUrl  String?
  customerSignatureName String?
  completedById         String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking               Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  completedBy           User?           @relation("JobReportCompletedBy", fields: [completedById], references: [id])

  @@index([tenantId, status, completedAt])
  @@index([tenantId, completedById])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  tenantId    String
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitCents   Int
  totalCents  Int
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
}

model MessageLog {
  id         String           @id @default(cuid())
  tenantId   String
  customerId String?
  direction  MessageDirection
  provider   MessageProvider
  content    String
  metadata   Json?
  createdAt  DateTime         @default(now())
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer?        @relation(fields: [customerId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, customerId])
}

model AutomationRule {
  id           String            @id @default(cuid())
  tenantId     String
  trigger      AutomationTrigger
  provider     MessageProvider   @default(WHATSAPP)
  template     String
  whatsappTemplateId String?
  active       Boolean           @default(true)
  delayMinutes Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappTemplate WhatsAppTemplate? @relation(fields: [whatsappTemplateId], references: [id], onDelete: SetNull)
  runs         AutomationRun[]

  @@unique([tenantId, trigger])
  @@index([tenantId, active])
  @@index([tenantId, whatsappTemplateId])
}

model WhatsAppTemplate {
  id            String                   @id @default(cuid())
  tenantId      String
  trigger       AutomationTrigger?
  name          String
  language      String                   @default("en_US")
  category      WhatsAppTemplateCategory @default(UTILITY)
  status        WhatsAppTemplateStatus   @default(DRAFT)
  body          String
  sampleValues  Json?
  variableKeys  String[]                 @default([])
  metaTemplateId String?
  rejectionReason String?
  active        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automationRules AutomationRule[]

  @@unique([tenantId, name, language])
  @@index([tenantId, status])
  @@index([tenantId, trigger])
}

model AutomationRun {
  id             String              @id @default(cuid())
  tenantId       String
  ruleId         String?
  customerId     String?
  bookingId      String?
  invoiceId      String?
  trigger        AutomationTrigger
  provider       MessageProvider
  status         AutomationRunStatus @default(PENDING)
  scheduledFor   DateTime
  sentAt         DateTime?
  content        String?
  error          String?
  idempotencyKey String
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule           AutomationRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  customer       Customer?           @relation(fields: [customerId], references: [id])
  booking        Booking?            @relation(fields: [bookingId], references: [id])
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, trigger])
}

model WebhookEvent {
  id              String             @id @default(cuid())
  tenantId        String?
  provider        WebhookProvider
  providerEventId String?
  status          WebhookEventStatus @default(RECEIVED)
  payload         Json
  error           String?
  createdAt       DateTime           @default(now())
  processedAt     DateTime?
  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, providerEventId])
  @@index([tenantId, createdAt])
  @@index([provider, status])
}

model ReceptionistConfig {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  enabled              Boolean  @default(true)
  displayName          String   @default("AI Receptionist")
  tone                 String   @default("warm, concise, professional")
  businessHours        Json?
  serviceArea          String?
  fallbackMessage      String   @default("Thanks for reaching out. A team member will follow up shortly.")
  handoffKeywords      String[] @default(["manager", "human", "representative", "call me"])
  quoteDisclaimer      String   @default("Final pricing may change after confirming job details.")
  bookingBufferMinutes Int      @default(30)
  maxAdvanceDays       Int      @default(30)
  model                String   @default("gpt-4.1-mini")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Conversation {
  id             String                @id @default(cuid())
  tenantId       String
  customerId     String?
  channel        MessageProvider       @default(WEB_CHAT)
  status         ConversationStatus    @default(OPEN)
  lastMessageAt  DateTime              @default(now())
  assignedToId   String?
  followUpAt     DateTime?
  resolvedAt     DateTime?
  handedOffAt    DateTime?
  handedOffToId  String?
  handoffReason  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer?             @relation(fields: [customerId], references: [id])
  assignedTo     User?                 @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  handedOffTo    User?                 @relation("ConversationHandoff", fields: [handedOffToId], references: [id])
  messages       ConversationMessage[]
  bookingIntents BookingIntent[]
  leads          Lead[]

  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, customerId])
}

model ConversationMessage {
  id             String                  @id @default(cuid())
  tenantId       String
  conversationId String
  role           ConversationMessageRole
  content        String
  metadata       Json?
  createdAt      DateTime                @default(now())
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, createdAt])
}

model BookingIntent {
  id               String              @id @default(cuid())
  tenantId         String
  conversationId   String
  customerId       String?
  serviceId        String?
  bookingId        String?
  status           BookingIntentStatus @default(COLLECTING)
  requestedDate    DateTime?
  preferredWindow  String?
  address          String?
  notes            String?
  quotedPriceCents Int?
  missingFields    String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation     Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer         Customer?           @relation(fields: [customerId], references: [id])
  service          Service?            @relation(fields: [serviceId], references: [id])
  booking          Booking?            @relation(fields: [bookingId], references: [id])
  lead             Lead?

  @@index([tenantId, status])
  @@index([tenantId, conversationId])
}

model Lead {
  id                    String         @id @default(cuid())
  tenantId              String
  customerId            String?
  conversationId        String?
  bookingIntentId       String?        @unique
  bookingId             String?
  assignedToId          String?
  status                LeadStatus     @default(NEW)
  source                LeadSource     @default(MANUAL)
  title                 String
  estimatedValueCents   Int?
  conversionProbability Int            @default(25)
  followUpAt            DateTime?
  wonLostReason         String?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer              Customer?      @relation(fields: [customerId], references: [id])
  conversation          Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  bookingIntent         BookingIntent? @relation(fields: [bookingIntentId], references: [id], onDelete: SetNull)
  booking               Booking?       @relation(fields: [bookingId], references: [id])
  assignedTo            User?          @relation("LeadAssignee", fields: [assignedToId], references: [id])

  @@index([tenantId, status, followUpAt])
  @@index([tenantId, source])
  @@index([tenantId, assignedToId])
  @@index([tenantId, customerId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId])
}

model PlatformSupportNote {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String?
  note      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User?    @relation("PlatformSupportNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([authorId])
}

model PlatformSupportAccess {
  id        String    @id @default(cuid())
  tenantId  String
  adminId   String
  reason    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admin     User      @relation("PlatformSupportAccessAdmin", fields: [adminId], references: [id])

  @@index([tenantId, createdAt])
  @@index([adminId, createdAt])
}

model PlatformBillingEvent {
  id              String           @id @default(cuid())
  tenantId        String
  actorId         String?
  type            BillingEventType
  amountCents     Int?
  currency        String           @default("usd")
  provider        String           @default("manual")
  providerEventId String?
  note            String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor           User?            @relation("PlatformBillingEventActor", fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([actorId])
  @@index([type, createdAt])
}
